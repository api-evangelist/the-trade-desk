    {
      "term": "IngestAdvertiserData",
      "type": "operation",
      "description": "Upload first-party data for the specified ID for use in audience targeting.",
      "path": "/data/advertiser",
      "method": "POST"
    },
    {
      "term": "IngestThirdPartyData",
      "type": "operation",
      "description": "Upload third-party data for the specified data provider for use in audience targeting.",
      "path": "/data/thirdparty",
      "method": "POST"
    },
    {
      "term": "IngestOfflineConversionData",
      "type": "operation",
      "description": "Upload offline conversion data for the specified data provider.",
      "path": "/providerapi/offlineconversion",
      "method": "POST"
    },
    {
      "term": "DataSubjectRequestAdvertiserData",
      "type": "operation",
      "description": "Delete IDs shared with The Trade Desk for the specified advertiser ID.",
      "path": "/data/deletion-optout/advertiser",
      "method": "POST"
    },
    {
      "term": "DataSubjectRequestMerchantData",
      "type": "operation",
      "description": "Delete IDs shared with The Trade Desk via a product catalog for the specified merchant ID.",
      "path": "/data/deletion-optout/merchant",
      "method": "POST"
    },
    {
      "term": "DataSubjectRequestThirdPartyData",
      "type": "operation",
      "description": "Delete IDs shared with The Trade Desk for the specified data provider ID.",
      "path": "/data/deletion-optout/thirdparty",
      "method": "POST"
    },
    {
      "term": "TTD-Auth",
      "type": "authentication",
      "description": "Authentication token header used in all The Trade Desk API requests"
    },
    {
      "term": "DSP",
      "type": "concept",
      "description": "Demand-Side Platform - a technology platform used to buy digital advertising programmatically"
    },
    {
      "term": "First-Party Data (1PD)",
      "type": "concept",
      "description": "Advertiser's own customer data used for audience targeting"
    },
    {
      "term": "Third-Party Data (3PD)",
      "type": "concept",
      "description": "External data provider audience segments for targeting"
    },
    {
      "term": "DSR",
      "type": "concept",
      "description": "Data Subject Request - deletion and opt-out requests for privacy compliance"
    },
    {
      "term": "CAPI",
      "type": "concept",
      "description": "Conversions API - for sending offline conversion events"
    },
    {
      "term": "Offline Conversion",
      "type": "concept",
      "description": "Conversion event that happens outside the digital tracking (e.g., in-store purchase) attributed back to ad campaigns"
    },
    {
      "term": "UID2",
      "type": "concept",
      "description": "Unified ID 2.0 - a privacy-conscious identifier based on hashed email addresses"
    },
    {
      "term": "EUID",
      "type": "concept",
      "description": "European Unified ID - the European counterpart to UID2"
    },
    {
      "term": "Programmatic Advertising",
      "type": "concept",
      "description": "Automated buying and selling of digital advertising using real-time data"
    },
    {
      "term": "Audience Segment",
      "type": "concept",
      "description": "A group of users with shared attributes for targeted advertising"
    }
  ]
